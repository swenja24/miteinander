# Vollständiger, kleingeschriebener GHCR-Image-Name
GHCR_IMAGE=ghcr.io/dein-github-name/dein-repository

# Vor dem ersten Start ändern
APP_PASSWORD=BITTE-EIN-STARKES-PASSWORT-EINTRAGEN

# Verantwortliche Stelle, angezeigt unter Hilfe & Datenschutz
DATA_CONTROLLER_NAME=
DATA_CONTROLLER_CONTACT=

# Optional: datensparsame E-Mail-Hinweise über neue Informationen
APP_BASE_URL=https://miteinander.example.de
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
